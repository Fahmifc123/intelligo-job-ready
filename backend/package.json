{
  "name": "intelligo-job-ready-backend",
  "version": "1.0.0",
  "author": "Fahira",
  "license": "",
  "description": "Intelligo Job Ready backend code",
  "packageManager": "pnpm@10.2.0",
  "type": "module",
  "homepage": "https://intelligo.id",
  "keywords": [
    "fastify",
    "typescript",
    "template",
    "api",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && copyfiles -u 1 src/locales/**/* dist/src",
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development node --watch src/server.ts | pino-pretty --colorize",
    "lint": "biome check src --apply",
    "format": "biome format src --write",
    "db:generate": "drizzle-kit generate",
    "db:generate:dev": "cross-env NODE_ENV=development drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:dev": "cross-env NODE_ENV=development drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:dev": "cross-env NODE_ENV=development drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:drop:dev": "cross-env NODE_ENV=development drizzle-kit drop",
    "db:init_data": "cross-env NODE_ENV=production ts-node ./src/scripts/init-data.ts --trace-warnings",
    "db:init_data_dev": "cross-env NODE_ENV=development ts-node ./src/scripts/init-data.ts --trace-warnings"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@fastify/autoload": "^6.3.0",
    "@fastify/compress": "^8.0.3",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@scalar/fastify-api-reference": "^1.28.23",
    "@sinclair/typebox": "^0.34.33",
    "axios": "^1.13.1",
    "better-auth": "^1.2.7",
    "close-with-grace": "^2.2.0",
    "commander": "^14.0.0",
    "copyfiles": "^2.4.1",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.44.1",
    "env-schema": "^6.0.1",
    "fastify": "^5.3.2",
    "fastify-better-auth": "^1.1.0",
    "fastify-i18n": "^3.0.0",
    "fastify-plugin": "^5.0.1",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "pg": "^8.15.6",
    "pino": "^9.6.0",
    "pm2": "^6.0.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@types/lint-staged": "~13.3.0",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.11.14",
    "@types/sinon": "^17.0.4",
    "c8": "^10.1.3",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "lint-staged": "16.1.0",
    "pino-pretty": "13.0.0",
    "rimraf": "^6.0.1",
    "sinon": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=23.6.0",
    "pnpm": ">=10.2.0"
  },
  "lint-staged": {
    "{src,test}/**/*.{ts,js,json}": "pnpm run check"
  }
}
